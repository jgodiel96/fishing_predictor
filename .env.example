# =============================================================================
# FISHING PREDICTOR - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your credentials
# NEVER commit the .env file to version control!
#
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Global Fishing Watch API
# -----------------------------------------------------------------------------
# Required for fishing activity data (AIS-based)
# Get your free API key at: https://globalfishingwatch.org/our-apis/
# 1. Click "Request API Access"
# 2. Fill the form (free for research/personal use)
# 3. You'll receive the key via email
GFW_API_KEY=your_gfw_api_key_here

# -----------------------------------------------------------------------------
# NASA Earthdata (for MUR SST - high resolution)
# -----------------------------------------------------------------------------
# Optional: For 1km resolution SST data
# Register at: https://urs.earthdata.nasa.gov/users/new
EARTHDATA_USER=your_earthdata_email
EARTHDATA_PASS=your_earthdata_password

# -----------------------------------------------------------------------------
# Copernicus Marine (backup SST source)
# -----------------------------------------------------------------------------
# Optional: For 5km resolution SST data
# Register at: https://data.marine.copernicus.eu/register
COPERNICUS_USER=your_copernicus_email
COPERNICUS_PASS=your_copernicus_password

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
# - At minimum, you need GFW_API_KEY for fishing activity data
# - NOAA SST works without any credentials (public API)
# - Earthdata and Copernicus are optional backup sources for SST
# - All credentials are processed locally and never transmitted except to
#   their respective official APIs
